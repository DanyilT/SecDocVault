rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocOwner(docId) {
       let docPath = 'vault/' + docId;
       return isSignedIn() && firestore.exists(/databases/(default)/documents/$(docPath))
         && firestore.get(/databases/(default)/documents/$(docPath)).data.owner == request.auth.uid;
    }

    function isOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    function hasActiveShare(docId) {
      let grantPath = /databases/(default)/documents/vault/$(docId)/sharedUsers/$(request.auth.uid);
      return isSignedIn()
        && firestore.exists(grantPath)
        && !firestore.get(grantPath).data.keys().hasAny(['revokedAt']);
    }

    function belowSizeLimit() {
      return request.resource.size <= 10 * 1024 * 1024; // 10 MB limit
    }

    function isEncryptedJson() {
      return request.resource.contentType == 'application/json';
    }

    match /vault/{ownerUid}/{docId}/{fileName} {
      allow create: if isOwner(ownerUid) && belowSizeLimit() && isEncryptedJson();
      allow get: if isOwner(ownerUid) || hasActiveShare(docId) || isDocOwner(docId);
      allow update: if isOwner(ownerUid) && belowSizeLimit() && isEncryptedJson();
      allow delete: if isOwner(ownerUid);
    }
  }
}
