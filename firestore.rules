rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return isSignedIn() && docData.owner == request.auth.uid;
    }

    function hasActiveShare(docId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/vault/$(docId)/sharedUsers/$(request.auth.uid))
        && (
          !('revokedAt' in get(/databases/$(database)/documents/vault/$(docId)/sharedUsers/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/vault/$(docId)/sharedUsers/$(request.auth.uid)).data.revokedAt == null
        )
        && get(/databases/$(database)/documents/vault/$(docId)/sharedUsers/$(request.auth.uid)).data.expiresAt > request.time;
    }

    match /vault/{docId} {
      allow create: if isSignedIn() && request.resource.data.owner == request.auth.uid;
      allow read: if isOwner(resource.data) || hasActiveShare(docId);
      allow update, delete: if isOwner(resource.data);
    }

    match /vault/{docId}/sharedUsers/{recipientUid} {
      allow read: if isSignedIn() && (recipientUid == request.auth.uid || resource.data.recipientUid == request.auth.uid || isOwner(get(/databases/$(database)/documents/vault/$(docId)).data));
      allow create, update, delete: if isOwner(get(/databases/$(database)/documents/vault/$(docId)).data)
        && request.resource.data.recipientUid == recipientUid;
    }

    match /vaultUsers/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    match /vaultKeyBackups/{ownerId} {
      allow read, delete: if isSignedIn() && request.auth.uid == ownerId;
      allow create, update: if isSignedIn()
        && request.auth.uid == ownerId
        && request.resource.data.owner == request.auth.uid;
    }
  }
}
